# === HookahBook Environment Variables ===
# Copy this file to .env and fill in real values
# NEVER commit .env to git!

# --- App ---
APP_NAME=HookahBook
APP_ENV=development
# development | production
DEBUG=false

# --- Security ---
# Generate with: python scripts/generate_secrets.py
# Or: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_real_secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_a_real_key
# JWT access token lifetime in minutes (default: 30)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT refresh token lifetime in days (default: 7)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/hookahbook.db

# --- CORS ---
# Comma-separated allowed origins
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# --- Telegram ---
# Get from @BotFather: /newbot
TELEGRAM_BOT_TOKEN=CHANGE_ME_get_from_botfather

# --- SMS (fallback auth) ---
SMS_PROVIDER=smsru
SMS_API_KEY=CHANGE_ME_get_from_sms_provider

# --- Web Push (VAPID) --- Phase 3 / T-110
# Generate keys with: python scripts/generate_secrets.py --vapid
# Or: from pywebpush import webpush; webpush.generate_vapid_keys()
VAPID_PRIVATE_KEY=CHANGE_ME_generate_vapid_keys
VAPID_PUBLIC_KEY=CHANGE_ME_generate_vapid_keys
# Must be a valid mailto: or https: URL
VAPID_CLAIMS_EMAIL=admin@yourdomain.com

# --- Domain ---
DOMAIN=yourdomain.com
