# === HookahBook Frontend Environment Variables ===
# Copy this file to frontend/.env and fill in values
# Variables prefixed with VITE_ are exposed to the browser bundle — do NOT put secrets here!

# --- API ---
# Backend API base URL (for production; in dev, proxied via vite.config.ts)
VITE_API_URL=https://yourdomain.com/api

# --- Web Push (VAPID) --- Phase 3 / T-110
# This is the PUBLIC VAPID key — safe to expose to the browser.
# Must match VAPID_PUBLIC_KEY in backend .env
# Generate: python scripts/generate_secrets.py --vapid
VITE_VAPID_PUBLIC_KEY=CHANGE_ME_same_as_backend_VAPID_PUBLIC_KEY

# --- Telegram ---
# Telegram Bot username (without @), used for Login Widget
VITE_TELEGRAM_BOT_USERNAME=YourBotUsername
